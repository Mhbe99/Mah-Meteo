# TomTom Traffic API
TOMTOM_API_KEY=your_tomtom_api_key_here

# Gmail Configuration
SENDER_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=your_gmail_app_password
RECEIVER_EMAILS=email1@example.com,email2@example.com

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
ADMIN_PIN=change_me_admin_pin

# Render Cloud Sync (for meteo_open.py)
RENDER_URL=https://mah-meteo.onrender.com
RENDER_API_TOKEN=your-service-token-from-api-service-token-endpoint

# Database URL (for Render, use SQLite)
DATABASE_URL=sqlite:///./meteo_saas.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# Local / dev test scripts
TEST_USERNAME=service-meteo
TEST_PASSWORD=
INIT_CLIENT_USERNAME=service-meteo
INIT_CLIENT_PASSWORD=
INIT_CLIENT_EMAIL=client@example.com
ADMIN_USERNAME=service-meteo
